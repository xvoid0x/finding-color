; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Finding Colour"
config/description="A co-op action roguelite. Fight through a child's nightmare. Bring the colour back."
run/main_scene="res://scenes/menus/title_screen.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

SettingsManager="*res://autoload/settings_manager.gd"
GameManager="*res://autoload/game_manager.gd"
PhoneManager="*res://autoload/phone_manager.gd"
EventBus="*res://autoload/event_bus.gd"
MessageTypes="*res://autoload/message_types.gd"
ScreenshotManager="*res://autoload/screenshot_manager.gd"
CrackTextureGen="*res://autoload/crack_texture_gen.gd"
CameraShaker="*res://autoload/camera_shaker.gd"
HitstopManager="*res://autoload/hitstop_manager.gd"
FloorManager="*res://autoload/floor_manager.gd"
AiRunEngine="*res://autoload/ai_run_engine.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/openclaw/plugin.cfg")

